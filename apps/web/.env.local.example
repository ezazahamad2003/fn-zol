# Next.js loads env from apps/web/.env.local. Copy ../../.env.local.example here
# as .env.local — it is the canonical, fully-documented list.
USE_STUBS=true

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# VAPI (USE_STUBS=false)
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=

# After-call extraction (OpenAI)
OPENAI_API_KEY=

# Google Calendar (optional — dormant until set)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
