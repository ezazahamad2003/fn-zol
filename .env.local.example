# =============================================================================
# ZOL — environment variables
# Copy this file to apps/web/.env.local. Stubs are ON by default — the app runs
# fully locally on seeded data with NO real third-party credentials.
# =============================================================================

# Master switch. true = run every external service against its in-process stub
# adapter (no spend). false = use the real adapters (requires the keys below).
USE_STUBS=true

# -----------------------------------------------------------------------------
# Supabase (required — the DB + Auth are real)
# Local: the defaults printed by `supabase start`. Prod: your project's values.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# -----------------------------------------------------------------------------
# App URL — used for OAuth redirects. In prod set to your real domain.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# VAPI (only when USE_STUBS=false) — voice platform.
# VAPI_API_KEY: your PRIVATE/server key (provisions assistants + numbers).
# VAPI_WEBHOOK_SECRET: any random string; sent on every webhook and verified by
#   the edge functions. Set the SAME value in Supabase secrets (below).
# No separate Deepgram/ElevenLabs/Cartesia keys needed — VAPI bundles them.
# Per-tenant assistant/phone ids live on the `tenants` row, NOT here.
# -----------------------------------------------------------------------------
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# After-call task extraction (only when USE_STUBS=false). Set ONE.
# Anthropic is the default; falls back to a regex heuristic if neither is set.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Google Calendar (optional — calendar booking stays dormant until these are
# set). Per-tenant OAuth: each business connects their own Google in Settings.
# Create an OAuth 2.0 Client (Web application) in Google Cloud Console, enable
# the Google Calendar API, and add the redirect URI below to the client.
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
