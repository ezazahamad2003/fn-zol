# =============================================================================
# ZOL — environment variables
# Copy this file to .env.local. Stubs are ON by default — the app runs fully
# locally on seeded data with NO real third-party credentials.
# =============================================================================

# Master switch. true = run every external service against its in-process stub
# adapter. false = use the real adapters (requires the keys below).
USE_STUBS=true

# -----------------------------------------------------------------------------
# Supabase (required even in stub mode — the DB is real, but local)
# -----------------------------------------------------------------------------
# For local dev these are the defaults printed by `supabase start`.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# -----------------------------------------------------------------------------
# VAPI (only needed when USE_STUBS=false)
# Per-tenant assistant/phone ids live on the `tenants` row, NOT here.
# -----------------------------------------------------------------------------
VAPI_API_KEY=

# -----------------------------------------------------------------------------
# OpenAI (only needed when USE_STUBS=false) — model used by VAPI assistants
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Google Calendar (only needed when USE_STUBS=false)
# Use a service account with domain-wide delegation, OR per-tenant OAuth.
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
